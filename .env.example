# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://life:life@localhost:5432/life

# Single-user auth for /api/* — generate with: openssl rand -hex 24
API_TOKEN=change-me-generate-a-real-one
# Same value, exposed to the web app by Vite
VITE_API_TOKEN=change-me-generate-a-real-one

# API port
PORT=3001

# Obsidian vault (Phase 4 — VaultStore)
VAULT_PATH=/Users/sienn/Library/Mobile Documents/iCloud~md~obsidian/Documents/Notes/Notes

# Phase 1: Things — shared secret for the iOS Shortcut webhook (openssl rand -hex 24)
# THINGS_WEBHOOK_SECRET=
